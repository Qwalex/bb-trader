FROM node:22-alpine
WORKDIR /app

COPY package.json package-lock.json ./
COPY packages ./packages
COPY apps ./apps

RUN npm ci

WORKDIR /app/packages/shared
RUN npm run build

WORKDIR /app/apps/api
# Только для prisma generate на этапе сборки (реальная БД задаётся в runtime).
ENV DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/_build?schema=public
RUN npx prisma generate && npm run build

EXPOSE 3001
CMD ["sh", "-c", "npx prisma migrate deploy && node dist/main.js"]
