{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "npm run build -w @repo/shared && npm run build -w api"
      ]
    }
  },
  "deploy": {
    "startCommand": "npm run start:railway --workspace=api"
  }
}
