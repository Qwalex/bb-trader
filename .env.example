# Copy this file to `.env` and fill in real values.
# Do not commit your real `.env`.

# Deployment / routing
STACK_SLUG=trade
# Внутри Docker-сети API всегда на порту контейнера 3001 (не путать с host mapping вроде 127.0.0.1:3011).
WEB_API_INTERNAL_URL=http://api:3001
WEB_ORIGIN=http://localhost:3003
# If you need several allowed origins for API CORS, uncomment:
# WEB_CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003

# API
API_PORT=3001
API_HOST=0.0.0.0
API_SWAGGER_SERVER=/trade-api
API_ENABLE_SWAGGER=true
LOG_LEVEL=log

# Web
NEXT_BASE_PATH=/trade
NEXT_PUBLIC_API_URL=/trade-api
NEXT_PUBLIC_DISPLAY_TIMEZONE=Europe/Moscow
# Публичный URL веб-приложения (с basePath). В Docker на VPS обязателен реальный хост, иначе редиректы auth уйдут на localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3003/trade

# Supabase
SUPABASE_PROJECT_ID=signalsbot
SUPABASE_DB_PASSWORD=replace_with_a_strong_postgres_password
SUPABASE_JWT_SECRET=replace_with_a_long_jwt_secret
# Ключи — именно JWT (три сегмента eyJ...), HS256 с тем же SUPABASE_JWT_SECRET, что у GoTrue. Не opaque sb_secret_… / sb_publishable_…
# Если меняли секрет и не пересобрали ключи, или в Studio «malformed JWT» — перегенерировать:
#   SUPABASE_JWT_SECRET='текущий_секрет' sh scripts/supabase-jwt-keys-from-secret.sh
# и обновить все четыре ключа ниже одинаковыми парами.
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_DISABLE_SIGNUP=false
# Адрес From в письмах; у многих SMTP (Timeweb, Gmail и т.д.) он должен совпадать с ящиком
# SUPABASE_SMTP_USER или быть явно разрешённым алиасом, иначе 550 5.7.1 «not allowed to send as …».
SUPABASE_SMTP_ADMIN_EMAIL=no-reply@example.com
SUPABASE_SMTP_HOST=smtp.example.com
SUPABASE_SMTP_PORT=587
SUPABASE_SMTP_USER=smtp-user
SUPABASE_SMTP_PASS=smtp-password
SUPABASE_SMTP_SENDER_NAME=SignalsBot
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY_SERVER=replace_with_supabase_service_role_key

# Logflare / Studio analytics (должны быть разными; например: openssl rand -hex 16)
LOGFLARE_PUBLIC_ACCESS_TOKEN=7e82c6a0097641cf321dca1ee16c2ebd
LOGFLARE_PRIVATE_ACCESS_TOKEN=acb96e7b9c35d1104d760de32e7c53c7

# Database
DATABASE_URL=postgresql://postgres:replace_with_a_strong_postgres_password@db:5432/postgres?schema=public
DIRECT_URL=postgresql://postgres:replace_with_a_strong_postgres_password@db:5432/postgres?schema=public
# Temporary fallback workspace id until full tenant context wiring is completed.
BOOTSTRAP_WORKSPACE_ID=

# Optional non-UI env-only overrides
APPLOG_DB_SKIP_DEBUG=0
TELEGRAM_STARTUP_MESSAGE=
