generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Signal {
  id             String   @id @default(cuid())
  cabinetId      String?
  cabinet        Cabinet? @relation(fields: [cabinetId], references: [id], onDelete: SetNull)
  pair           String
  direction      String
  entries        String // JSON number[]
  /// true — entries [low,high] — одна зона входа (не DCA)
  entryIsRange   Boolean  @default(false)
  stopLoss       Float
  takeProfits    String // JSON number[]
  leverage       Int
  /// Номинал в USDT (fallback в БД 10; фактический дефолт — настройка DEFAULT_ORDER_USD)
  orderUsd       Float    @default(10)
  capitalPercent Float    @default(0)
  source         String?
  sourceChatId   String?
  sourceMessageId String?
  signalExternalId String?
  rawMessage     String?
  status         String // PENDING, OPEN, ORDERS_PLACED, CLOSED_WIN, CLOSED_LOSS, CLOSED_MIXED, FAILED
  realizedPnl    Float?
  /// true, если сделка закрылась ликвидацией позиции.
  liquidation    Boolean  @default(false)
  /// Плечо сделки на момент фиксации ликвидации (для статистики).
  liquidationLeverage Int?
  closedAt       DateTime?
  /// Индекс последнего применённого шага подтягивания SL: -1 = не применялось, 0 = BE после TP1, 1 = SL на TP1 после TP2, …
  tpSlStep       Int      @default(-1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  orders         Order[]
  events         SignalEvent[]

  @@index([sourceChatId, sourceMessageId])
  @@index([sourceChatId, signalExternalId])
  @@index([cabinetId, deletedAt, createdAt])
  @@index([cabinetId, deletedAt, closedAt])
  @@index([deletedAt, createdAt])
  @@index([deletedAt, closedAt])
}

model RecalcClosedPnlJob {
  id         String   @id
  status     String // queued | running | completed | failed
  dryRun     Boolean
  limit      Int
  createdAt  DateTime @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  resultJson String?
  error      String?

  @@index([createdAt])
}

model SignalEvent {
  id        String   @id @default(cuid())
  signalId  String
  signal    Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  type      String
  payload   String?
  createdAt DateTime @default(now())

  @@index([signalId, createdAt])
}

model Order {
  id           String    @id @default(cuid())
  signalId     String
  signal       Signal    @relation(fields: [signalId], references: [id], onDelete: Cascade)
  bybitOrderId String?
  orderKind    String // ENTRY, DCA, TP, SL
  side         String
  price        Float?
  qty          Float?
  status       String
  pnl          Float?
  filledAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([signalId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Один снимок суммарного USDT-баланса (equity) в сутки — для графика на дашборде.
model BalanceSnapshot {
  id        String   @id @default(cuid())
  cabinetId String?
  cabinet   Cabinet? @relation(fields: [cabinetId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  totalUsd  Float

  @@index([cabinetId, createdAt])
  @@index([createdAt])
}

model AppLog {
  id        String   @id @default(cuid())
  cabinetId String?
  cabinet   Cabinet? @relation(fields: [cabinetId], references: [id], onDelete: SetNull)
  level     String // info | warn | error | debug
  category  String // openrouter | telegram | bybit | orders | system
  message   String
  payload   String? // JSON
  createdAt DateTime @default(now())

  @@index([cabinetId, createdAt])
  @@index([createdAt])
  @@index([category, createdAt])
}

model TgUserbotChat {
  id        String   @id @default(cuid())
  chatId    String   @unique
  title     String
  username  String?
  enabled   Boolean  @default(false)
  /// Приоритет источника для замены активного сигнала: больше = приоритетнее
  sourcePriority Int @default(0)
  /// Переопределение плеча для сигналов из этого чата; null = брать DEFAULT_LEVERAGE
  defaultLeverage Int?
  /// Принудительное плечо (всегда подменяет плечо из сигнала); приоритет над глобальным FORCED_LEVERAGE; null = выкл.
  forcedLeverage Int?
  /// Режим выбора плеча из диапазона: min | max | mid; null = наследовать глобальный LEVERAGE_RANGE_MODE
  leverageRangeMode String?
  /// Минимально допустимое плечо; null = наследовать глобальный MIN_ALLOWED_LEVERAGE
  minLeverage Int?
  /// Максимально допустимое плечо; null = наследовать глобальный MAX_ALLOWED_LEVERAGE
  maxLeverage Int?
  /// Дефолт суммы входа: USDT или процент от equity, как DEFAULT_ORDER_USD (например "10" или "10%"); null = только глобальная настройка
  defaultEntryUsd String?
  /// Увеличивать номинал до minQty биржи; null = брать глобальную настройку BUMP_TO_MIN_EXCHANGE_LOT
  minLotBump Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cabinetSources CabinetTelegramSource[]
}

model TgUserbotIngest {
  id             String   @id @default(cuid())
  chatId         String
  messageId      String
  dedupMessageKey String  @unique
  text           String?
  aiRequest      String?
  aiResponse     String?
  classification String // signal | result | other
  signalHash     String?
  status         String // ignored | duplicate_message | duplicate_signal | placed | parse_incomplete | parse_error | blocked_by_setting | place_error
  error          String?
  createdAt      DateTime @default(now())
  routes         CabinetIngestRoute[]

  @@index([chatId, messageId])
  @@index([signalHash])
  @@index([createdAt])
}

model TgUserbotSignalHash {
  hash      String   @id
  createdAt DateTime @default(now())
}

model TgUserbotFilterExample {
  id         String   @id @default(cuid())
  groupName  String
  kind       String // signal | close | result | reentry | ignore
  example    String
  requiresQuote Boolean @default(false)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([groupName, kind, enabled])
  @@index([createdAt])
}

model TgUserbotFilterPattern {
  id         String   @id @default(cuid())
  groupName  String
  kind       String // signal | close | result | reentry | ignore
  pattern    String
  requiresQuote Boolean @default(false)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([groupName, kind, enabled])
  @@index([createdAt])
}

model TgUserbotPublishGroup {
  id            String   @id @default(cuid())
  cabinetId     String?
  cabinet       Cabinet? @relation(fields: [cabinetId], references: [id], onDelete: SetNull)
  title         String
  chatId        String
  enabled       Boolean  @default(true)
  publishEveryN Int      @default(1)
  signalCounter Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([cabinetId, chatId])
  @@index([cabinetId, enabled])
}

model TgUserbotMirrorMessage {
  id                     String   @id @default(cuid())
  cabinetId              String?
  cabinet                Cabinet? @relation(fields: [cabinetId], references: [id], onDelete: SetNull)
  publishGroupId         String
  ingestId               String
  sourceChatId           String
  sourceMessageId        String
  rootSourceChatId       String?
  rootSourceMessageId    String?
  kind                   String // signal | result | cancel
  status                 String // posted | skipped_by_n | skipped_no_root | failed
  targetChatId           String
  targetMessageId        String?
  replyToTargetMessageId String?
  error                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([publishGroupId, ingestId, kind])
  @@index([cabinetId, createdAt])
  @@index([publishGroupId, sourceChatId, sourceMessageId, kind])
  @@index([publishGroupId, rootSourceChatId, rootSourceMessageId, kind])
  @@index([createdAt])
}

model DiagnosticRun {
  id          String   @id @default(cuid())
  status      String // running | completed | failed
  requestJson String?
  modelsJson  String // JSON string[]
  caseCount   Int      @default(0)
  summary     String?
  error       String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases        DiagnosticCase[]
  modelResults DiagnosticModelResult[]
  stepResults  DiagnosticStepResult[]
  logs         DiagnosticLog[]

  @@index([createdAt])
  @@index([status, createdAt])
}

model DiagnosticCase {
  id        String   @id @default(cuid())
  runId     String
  run       DiagnosticRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  ingestId  String?
  signalId  String?
  chatId    String?
  messageId String?
  title     String?
  status    String   @default("pending") // pending | completed | failed
  traceJson String // normalized trace payload for auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modelResults DiagnosticModelResult[]
  stepResults  DiagnosticStepResult[]
  logs         DiagnosticLog[]

  @@index([runId, createdAt])
  @@index([ingestId])
  @@index([signalId])
}

model DiagnosticModelResult {
  id          String   @id @default(cuid())
  runId       String
  caseId      String
  model       String
  status      String // ok | warning | error | unknown
  summary     String?
  rawResponse String?
  inputTokens Int?
  outputTokens Int?
  totalTokens Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  run         DiagnosticRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  diagnosticCase DiagnosticCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stepResults DiagnosticStepResult[]
  logs        DiagnosticLog[]

  @@unique([runId, caseId, model])
  @@index([runId, model])
  @@index([caseId, createdAt])
}

model DiagnosticStepResult {
  id              String   @id @default(cuid())
  runId           String
  caseId          String
  modelResultId   String?
  stepKey         String
  status          String // ok | warning | error | unknown
  comment         String?
  issuesJson      String?
  evidenceJson    String?
  missingContextJson String?
  recommendedFixesJson String?
  payloadJson     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  run           DiagnosticRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  diagnosticCase DiagnosticCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  modelResult   DiagnosticModelResult? @relation(fields: [modelResultId], references: [id], onDelete: Cascade)

  @@index([runId, caseId, createdAt])
  @@index([modelResultId, stepKey])
}

model DiagnosticLog {
  id            String   @id @default(cuid())
  runId         String
  caseId        String?
  modelResultId String?
  level         String // info | warn | error | debug
  category      String // diagnostics | openrouter | bybit | db | system
  message       String
  payload       String?
  createdAt     DateTime @default(now())

  run         DiagnosticRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  diagnosticCase DiagnosticCase? @relation(fields: [caseId], references: [id], onDelete: Cascade)
  modelResult DiagnosticModelResult? @relation(fields: [modelResultId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([caseId, createdAt])
}

model OpenrouterGenerationCost {
  id           String   @id @default(cuid())
  cabinetId    String?
  cabinet      Cabinet? @relation(fields: [cabinetId], references: [id], onDelete: SetNull)
  generationId String   @unique
  operation    String?
  chatId       String?
  source       String?
  ingestId     String?
  costUsd      Float?
  status       String   @default("pending") // pending | resolved | failed
  attempts     Int      @default(0)
  nextRetryAt  DateTime?
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([cabinetId, createdAt])
  @@index([status, nextRetryAt])
  @@index([createdAt])
  @@index([chatId, createdAt])
}

model Cabinet {
  id               String                 @id @default(cuid())
  slug             String                 @unique
  name             String
  isDefault        Boolean                @default(false)
  ownerUserId      String?
  ownerUser        AuthUser?              @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  members          CabinetMember[]
  settings         CabinetSetting[]
  appLogs          AppLog[]
  telegramSources  CabinetTelegramSource[]
  ingestRoutes     CabinetIngestRoute[]
  signals          Signal[]
  balanceSnapshots BalanceSnapshot[]
  openrouterCosts  OpenrouterGenerationCost[]
  publishGroups    TgUserbotPublishGroup[]
  mirrorMessages   TgUserbotMirrorMessage[]

  @@index([isDefault])
  @@index([ownerUserId, createdAt])
}

model CabinetMember {
  id             String   @id @default(cuid())
  cabinetId      String
  cabinet        Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  telegramUserId String
  role           String   @default("owner")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([cabinetId, telegramUserId])
  @@index([telegramUserId, isActive])
}

model CabinetSetting {
  id        String   @id @default(cuid())
  cabinetId String
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cabinetId, key])
  @@index([cabinetId, updatedAt])
}

model CabinetTelegramSource {
  id                String   @id @default(cuid())
  cabinetId         String
  cabinet           Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  chatId            String
  chat              TgUserbotChat @relation(fields: [chatId], references: [chatId], onDelete: Cascade)
  enabled           Boolean  @default(false)
  sourcePriority    Int      @default(0)
  defaultLeverage   Int?
  forcedLeverage    Int?
  leverageRangeMode String?
  minLeverage       Int?
  maxLeverage       Int?
  defaultEntryUsd   String?
  minLotBump        Boolean?
  martingaleMultiplier Float?
  tpSlStepStart     String?
  tpSlStepRange     Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([cabinetId, chatId])
  @@index([chatId, enabled])
}

model CabinetIngestRoute {
  id             String   @id @default(cuid())
  cabinetId      String
  cabinet        Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  ingestId       String
  ingest         TgUserbotIngest @relation(fields: [ingestId], references: [id], onDelete: Cascade)
  chatId         String
  classification String   @default("other")
  status         String   @default("queued")
  error          String?
  aiRequest      String?
  aiResponse     String?
  signalId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([cabinetId, ingestId])
  @@index([ingestId, createdAt])
  @@index([cabinetId, createdAt])
}

model AuthUser {
  id               String   @id @default(cuid())
  login            String   @unique
  passwordHash     String
  role             String   @default("user")
  telegramUserId   String?
  failedLoginCount Int      @default(0)
  firstLockUntil   DateTime?
  manualLock       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  resetCodes AuthPasswordReset[]
  cabinets  Cabinet[]

  @@index([role, createdAt])
  @@index([telegramUserId])
}

model AuthPasswordReset {
  id         String   @id @default(cuid())
  userId     String
  user       AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt, consumedAt])
}

model WorkerQueueJob {
  id         String   @id @default(cuid())
  queue      String
  jobKey     String   @unique
  payloadJson String
  status     String   @default("pending") // pending | running | completed | failed
  attempts   Int      @default(0)
  runAfter   DateTime @default(now())
  lockedAt   DateTime?
  finishedAt DateTime?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([queue, status, runAfter, createdAt])
  @@index([status, updatedAt])
}
